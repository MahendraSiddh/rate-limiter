# ─────────────────────────────────────────────────────────────────────────────
# redis.env — Tunable parameters for the Redis Cluster and Go decision engine
#
# Source this file via Docker Compose `env_file`, Kubernetes ConfigMap, or
# a local .envrc when running outside containers.
#
# Override any value by setting the variable in the environment before
# docker-compose up — the host environment always wins over this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Rate limiting parameters ─────────────────────────────────────────────────

# Maximum number of requests allowed within WINDOW_SECONDS for any single
# bucket (per-IP by default).  Modify per customer tier in the engine config.
MAX_TOKENS_PER_MIN=60

# Sliding-window width in seconds.  The Lua token_bucket.lua script uses this
# to prune expired ZSET members and to set the EXPIRE on the bucket key.
# Default: 60s → 60 requests / minute per IP.
WINDOW_SECONDS=60

# ── Cluster topology ──────────────────────────────────────────────────────────

# Comma-separated list of all cluster node endpoints.
# Used by the Go redis client (go-redis ClusterClient) to seed the
# topology discovery.  The client auto-discovers all remaining nodes
# via CLUSTER SLOTS / CLUSTER SHARDS after the first successful ping.
CLUSTER_NODES=redis-node-1:6379,redis-node-2:6379,redis-node-3:6379,redis-node-4:6379,redis-node-5:6379,redis-node-6:6379

# ── Memory limits (mirrors redis.conf, for env-substitution if using a
#    templated redis.conf with envsubst) ───────────────────────────────────────

REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=volatile-lru

# ── Connection pool (Go client) ───────────────────────────────────────────────

# Maximum connections per cluster node in the go-redis pool.
REDIS_POOL_SIZE=20

# Minimum number of idle connections kept alive per node.
REDIS_MIN_IDLE_CONNS=5

# Dial / read / write timeouts (milliseconds).
REDIS_DIAL_TIMEOUT_MS=2000
REDIS_READ_TIMEOUT_MS=500
REDIS_WRITE_TIMEOUT_MS=500

# ── ML model TTL ─────────────────────────────────────────────────────────────

# How long (seconds) a per-client model blob stays in Redis before expiry.
# Caller should re-upload after this window; get_set_model.lua will return
# nil and trigger a fresh baseline load.
MODEL_TTL_SECONDS=3600

# ── Prometheus / redis-exporter ───────────────────────────────────────────────

REDIS_EXPORTER_PORT=9121
