# ─────────────────────────────────────────────────────────────────────────────
# ml-sidecar/Makefile
# ─────────────────────────────────────────────────────────────────────────────

PYTHON        ?= python3
PIP           ?= pip3
PROTO_DIR     := proto
PROTO_SRC     := $(PROTO_DIR)/scorer.proto
PROTO_PY      := $(PROTO_DIR)/scorer_pb2.py
PROTO_GRPC_PY := $(PROTO_DIR)/scorer_pb2_grpc.py

IMAGE_NAME    ?= ml-sidecar
IMAGE_TAG     ?= latest

.PHONY: all proto install dev-install lint test build run clean help

# Default target
all: proto

## proto: Compile scorer.proto → Python gRPC stubs
proto: $(PROTO_PY) $(PROTO_GRPC_PY)

$(PROTO_PY) $(PROTO_GRPC_PY): $(PROTO_SRC)
	@echo "► Compiling proto stubs…"
	$(PYTHON) -m grpc_tools.protoc \
		-I $(PROTO_DIR) \
		--python_out=$(PROTO_DIR) \
		--grpc_python_out=$(PROTO_DIR) \
		$(PROTO_SRC)
	@# Fix relative import generated by grpc_tools (scorer_pb2_grpc imports scorer_pb2)
	@sed -i.bak 's/^import scorer_pb2/from proto import scorer_pb2/' \
		$(PROTO_GRPC_PY) && rm -f $(PROTO_GRPC_PY).bak
	@touch $(PROTO_DIR)/__init__.py
	@echo "► Proto stubs compiled."

## install: Install runtime dependencies
install:
	$(PIP) install --no-cache-dir -r requirements.txt

## dev-install: Install runtime + dev dependencies
dev-install:
	$(PIP) install --no-cache-dir -r requirements.txt
	$(PIP) install --no-cache-dir ruff mypy pytest pytest-asyncio httpx

## lint: Run ruff linter
lint:
	ruff check .

## baseline: Generate a synthetic baseline_iso.pkl model for dev use
baseline: proto
	$(PYTHON) -c "\
import pathlib, sys; sys.path.insert(0,'.');\
from models.isolation_forest import create_and_save_baseline;\
create_and_save_baseline(pathlib.Path('models/baseline_iso.pkl'));\
print('baseline_iso.pkl written')"

## test: Run unit tests
test: proto
	$(PYTHON) -m pytest tests/ -v

## build: Build the Docker image
build:
	docker build -t $(IMAGE_NAME):$(IMAGE_TAG) .

## run: Run the sidecar locally (requires Redis on redis:6379)
run: proto
	REDIS_URL=redis://localhost:6379/0 $(PYTHON) server.py

## retrain: Run the offline retrain script manually
retrain: proto
	$(PYTHON) training/retrain.py

## clean: Remove generated proto stubs and caches
clean:
	rm -f $(PROTO_PY) $(PROTO_GRPC_PY)
	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
	find . -name "*.pyc" -delete

## help: Show this help message
help:
	@grep -E '^## ' Makefile | sed 's/## /  /'
